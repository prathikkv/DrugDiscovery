# ── LLM Providers (at least one required for AI Insights) ────────────
# Primary: Anthropic Claude (recommended)
ANTHROPIC_API_KEY=sk-ant-...

# Fallback providers (optional)
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# ── Application Settings ──────────────────────────────────────────────
# Environment: development | production
APP_ENV=development

# Data directory (defaults to ./data relative to project root)
DATA_DIR=./data

# ── Streamlit Community Cloud Deploy ─────────────────────────────────
# Add ANTHROPIC_API_KEY as a secret in the Streamlit Cloud dashboard.
# All other keys are optional — showcase scenarios run without any API keys.
# Settings → Secrets → paste: ANTHROPIC_API_KEY = "sk-ant-..."
